{
  "name": "speakeasy",
  "version": "0.1.0",
  "private": true,
  "description": "Speakeasy Chrome extension scaffold.",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run scripts/build.ts",
    "deps:check": "depcruise --config .dependency-cruiser.cjs src",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test tests/unit",
    "test:contract": "bun test tests/contract",
    "verify": "bun run deps:check && bun run lint && bun run typecheck && bun run build && bun run test:unit && bun run test:contract",
    "test:gemini:canary": "bun run scripts/test-gemini.ts",
    "test:gemini": "bun run test:gemini:canary"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/chrome": "0.0.293",
    "dependency-cruiser": "17.3.8",
    "fake-indexeddb": "6.2.5",
    "happy-dom": "20.7.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@google/genai": "1.42.0",
    "@modelcontextprotocol/sdk": "1.26.0",
    "baseline-browser-mapping": "2.10.0",
    "caniuse-lite": "1.0.30001770"
  }
}
